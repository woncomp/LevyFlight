<Window x:Class="LevyFlight.LevyFlightSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:shell="clr-namespace:Microsoft.VisualStudio.Shell;assembly=Microsoft.VisualStudio.Shell.15.0"
        Title="Levy Flight Settings"
        Width="360"
        Height="150"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource {x:Static shell:VsBrushes.ToolWindowBackgroundKey}}"
        Foreground="{DynamicResource {x:Static shell:VsBrushes.WindowTextKey}}">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <CheckBox x:Name="DiagnosticCheckBox"
                  Content="Diagnostic"
                  VerticalAlignment="Top"
                  Foreground="{DynamicResource {x:Static shell:VsBrushes.WindowTextKey}}"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Width="76" Margin="0,0,8,0" IsDefault="True" Click="OkButton_Click">OK</Button>
            <Button Width="76" IsCancel="True">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>
